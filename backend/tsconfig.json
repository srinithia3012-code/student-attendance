{
    "compilerOptions":  {
                            "target":  "ESNext",
                            "module":  "NodeNext",
                            "moduleResolution":  "NodeNext",
                            "strict":  true,
                            "esModuleInterop":  true,
                            "outDir":  "./dist",
                            "rootDir":  "./src",
                            "skipLibCheck":  true
                        },
    "include":  [
                    "src/**/*.ts"
                ],
    "exclude":  [
                    "node_modules",
                    "dist",
                    "drizzle",
                    "drizzle.config.ts"
                ]
}
